{
  "name": "@easyssh/design-system",
  "version": "1.0.0",
  "description": "EasySSH Design System - Apple-level native UI components",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "specs",
    "tailwind.config.ts"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens/design-tokens.js",
      "types": "./dist/tokens/design-tokens.d.ts"
    },
    "./styles": {
      "import": "./dist/styles/theme.css",
      "require": "./dist/styles/theme.css"
    },
    "./hooks": {
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./utils": {
      "import": "./dist/utils/index.js",
      "types": "./dist/utils/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && cp src/styles/theme.css dist/styles/",
    "dev": "tsc --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "design-system",
    "ui",
    "components",
    "tailwind",
    "ssh",
    "terminal"
  ],
  "author": "EasySSH Team",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {}
}
