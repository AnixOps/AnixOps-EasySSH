# EasySSH Pro Server Environment Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8080

# Database - SQLite (default), PostgreSQL, or MySQL
DATABASE_URL=sqlite:./pro_server.db
# DATABASE_URL=postgres://user:pass@localhost/easyssh
# DATABASE_URL=mysql://user:pass@localhost/easyssh

# Redis - Required for sessions, rate limiting, and caching
REDIS_URL=redis://127.0.0.1:6379

# Security - CHANGE THESE IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7
ENCRYPTION_KEY=your-32-byte-encryption-key-here!

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECS=60

# Email Configuration (Optional - for invitation emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-username
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@easyssh.io

# SAML SSO Configuration (Optional)
SAML_ISSUER=https://easyssh.io/sso/saml
SAML_IDP_SSO_URL=https://idp.example.com/sso
SAML_IDP_CERT=MIIDXTCCAkWgAwIBAgIJAJC1HiIAZAiUMA0GCSqGSIb3Qa3BajELMAkGA1...

# OIDC SSO Configuration (Optional)
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_AUTHORIZATION_URL=https://idp.example.com/oauth2/authorize
OIDC_TOKEN_URL=https://idp.example.com/oauth2/token
OIDC_USERINFO_URL=https://idp.example.com/oauth2/userinfo
OIDC_REDIRECT_URL=https://easyssh.io/sso/oidc/callback
